{
  "name": "@playgenx/storage-react",
  "version": "0.1.1",
  "description": "React 19 hooks over an @playgenx/storage ArtifactStorage. Save / list / re-mount / delete artifacts from components.",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "eslint src",
    "test": "vitest --run"
  },
  "keywords": [
    "playgenx",
    "react",
    "storage"
  ],
  "author": "xorinf <118471720+xorinf@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xorinf/playgenx.git",
    "directory": "packages/storage-react"
  },
  "bugs": {
    "url": "https://github.com/xorinf/playgenx/issues"
  },
  "homepage": "https://github.com/xorinf/playgenx/tree/main/packages/storage-react",
  "publishConfig": {
    "access": "public"
  },
  "tsdown": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "sourcemap": true,
    "clean": true,
    "deps": {
      "alwaysBundle": [
        "^@playgenx/"
      ]
    }
  },
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@playgenx/storage": "workspace:*",
    "@playgenx/types": "workspace:*",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.2.17",
    "jsdom": "^25.0.1",
    "react": "^19.2.7",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}