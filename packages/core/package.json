{
  "name": "playgenx",
  "version": "0.4.0-beta.0",
  "description": "Open-source TypeScript SDK for generating interactive educational experiences from lecture context using LLMs.",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "llm",
    "education",
    "playground",
    "quiz",
    "simulation",
    "flashcards",
    "sdk"
  ],
  "author": "xorinf <118471720+xorinf@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xorinf/playgenx.git"
  },
  "bugs": {
    "url": "https://github.com/xorinf/playgenx/issues"
  },
  "homepage": "https://github.com/xorinf/playgenx",
  "scripts": {
    "build": "tsdown",
    "lint": "eslint src",
    "test": "vitest --run --passWithNoTests"
  },
  "publishConfig": {
    "access": "public"
  },
  "tsdown": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "sourcemap": true,
    "clean": true,
    "deps": {
      "alwaysBundle": [
        "^@playgenx/"
      ]
    }
  },
  "peerDependencies": {
    "typescript": "^5.6.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playgenx/observability": "workspace:*",
    "@playgenx/registry": "workspace:*",
    "@playgenx/types": "workspace:*",
    "@playgenx/utils": "workspace:*",
    "@playgenx/validators": "workspace:*",
    "@playgenx/parser": "workspace:*",
    "@playgenx/providers": "workspace:*",
    "@playgenx/prompts": "workspace:*",
    "@types/node": "^22.0.0",
    "zod": "^3.23.0"
  }
}
