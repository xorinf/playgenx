{
  "name": "@playgenx/core",
  "version": "0.1.0",
  "description": "Public PlayGenX SDK entry point. Exposes high-level APIs for generating interactive educational artifacts.",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "eslint src",
    "test": "vitest --run --passWithNoTests"
  },
  "dependencies": {
    "@playgenx/parser": "workspace:*",
    "@playgenx/prompts": "workspace:*",
    "@playgenx/providers": "workspace:*",
    "@playgenx/registry": "workspace:*",
    "@playgenx/types": "workspace:*",
    "@playgenx/validators": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "tsdown": {
    "entry": ["src/index.ts"],
    "format": ["esm"],
    "dts": true,
    "sourcemap": true,
    "clean": true,
    "deps": {
      "alwaysBundle": ["@playgenx/parser", "@playgenx/prompts", "@playgenx/providers", "@playgenx/registry", "@playgenx/types", "@playgenx/validators"]
    }
  }
}
