{
  "name": "@playgenx/observability",
  "version": "0.4.0",
  "description": "OpenTelemetry GenAI instrumentation for the playgenx pipeline. Optional peer dependency: @opentelemetry/api.",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "eslint src",
    "test": "vitest --run --passWithNoTests"
  },
  "tsdown": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "sourcemap": true,
    "clean": true,
    "deps": {
      "alwaysBundle": [
        "^@playgenx/"
      ]
    }
  },
  "keywords": [
    "playgenx",
    "opentelemetry",
    "observability",
    "genai"
  ],
  "author": "xorinf <118471720+xorinf@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xorinf/playgenx.git",
    "directory": "packages/observability"
  },
  "bugs": {
    "url": "https://github.com/xorinf/playgenx/issues"
  },
  "homepage": "https://github.com/xorinf/playgenx/tree/main/packages/observability",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
