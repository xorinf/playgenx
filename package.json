{
  "name": "playgenx-workspace",
  "version": "0.0.0",
  "description": "Root workspace for the playgenx monorepo. The published npm package is `playgenx` from packages/core.",
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter '@playgenx/*' --workspace-concurrency=1 run build && pnpm --filter playgenx run build && pnpm --filter playgenx-playground run build",
    "build:packages": "pnpm -r --filter '@playgenx/*' --workspace-concurrency=1 run build && pnpm --filter playgenx run build",
    "build:subpackages": "pnpm -r --filter '@playgenx/*' --workspace-concurrency=1 run build",
    "build:core": "pnpm --filter playgenx run build",
    "build:root": "tsdown",
    "dev": "pnpm -r --parallel --filter './packages/*' run build --watch",
    "dev:playground": "pnpm --filter playgenx-playground dev",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "test": "pnpm -r run test",
    "verify": "pnpm run lint && pnpm run build && pnpm run test",
    "prepublishOnly": "pnpm run verify"
  },
  "keywords": [
    "ai",
    "llm",
    "education",
    "playground",
    "quiz",
    "simulation",
    "flashcards",
    "sdk"
  ],
  "author": "xorinf <118471720+xorinf@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xorinf/playgenx.git"
  },
  "bugs": {
    "url": "https://github.com/xorinf/playgenx/issues"
  },
  "homepage": "https://github.com/xorinf/playgenx",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playgenx/parser": "workspace:*",
    "@playgenx/prompts": "workspace:*",
    "@playgenx/providers": "workspace:*",
    "@playgenx/registry": "workspace:*",
    "@playgenx/types": "workspace:*",
    "@playgenx/utils": "workspace:*",
    "@playgenx/validators": "workspace:*",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "playgenx": "workspace:*",
    "prettier": "^3.9.5",
    "tsdown": "^0.22.4",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "unrun": "^0.3.1",
    "vitest": "^4.1.10"
  }
}