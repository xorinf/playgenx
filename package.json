{
  "name": "playgenx",
  "version": "0.1.0",
  "description": "Open-source TypeScript SDK for generating interactive educational experiences from lecture context using LLMs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "build:root": "tsdown",
    "dev": "pnpm -r --parallel --filter './packages/*' run build --watch",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "test": "pnpm -r run test",
    "verify": "pnpm run lint && pnpm run build && pnpm run test",
    "prepublishOnly": "pnpm run verify"
  },
  "keywords": [
    "ai",
    "llm",
    "education",
    "playground",
    "quiz",
    "simulation",
    "flashcards",
    "sdk"
  ],
  "author": "xorinf <118471720+xorinf@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xorinf/playgenx.git"
  },
  "bugs": {
    "url": "https://github.com/xorinf/playgenx/issues"
  },
  "homepage": "https://github.com/xorinf/playgenx",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playgenx/core": "workspace:*",
    "@playgenx/parser": "workspace:*",
    "@playgenx/prompts": "workspace:*",
    "@playgenx/providers": "workspace:*",
    "@playgenx/registry": "workspace:*",
    "@playgenx/types": "workspace:*",
    "@playgenx/utils": "workspace:*",
    "@playgenx/validators": "workspace:*",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}